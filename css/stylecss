*{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/*styling slide show here!*/
.slideshow-container{
    position: relative;
    margin: 5px 0 0 0;
    max-height: 500px;
}

.myslide{
    display: none;
}

.prev,
.next{
    cursor: pointer;
    position: absolute;
    top: 50px;
    width: auto;
    margin-top: -22px;
    padding: 16px;
    color: white;
    font-weight: bold;
    font-size: 18px;
    transition: 0,6s ease;
    border-radius: 0 3px 3px 0;
    user-select: none;
}

.next
{
    right: 0;
    border-radius: 3px 0 0 3px;
}

.prev:hover
.next:hover
{
    background-color: black;
}

.text
{
    color: aliceblue;
    font-size: 15px;
    padding: 8px 12px;
    position: absolute;
    bottom: 8px;
    width: 100%;
}

.numbertext
{
    color: aliceblue;
    font-size: 12px;
    padding: 8px 12px;
    position: absolute;
    top: 0;
}

.dot 
{
    cursor: pointer;
    height: 15px;
    width: 15px;
    margin: 0 2px;
    background-color: aliceblue;
    border-radius: 50px;
    display: inline-block;
    transition: background-color 0.6s ease;
}

.active 
.dot:hover 
{
    background-color: azure;
}

.fade 
{
    animation-name: fade;
    animation-duration: 1.5s;
}

@keyframes fade 
{
    from 
    {
        opacity: .4;
    }
    to 
    {
        opacity: 1;
    }
}
